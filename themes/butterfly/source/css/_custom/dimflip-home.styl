#body-wrap.page
  background: #f7f4ee

body::before
  content: "Dimflip"
  position: fixed
  right: 18px
  bottom: 16px
  z-index: 1
  color: rgba(20, 24, 31, .08)
  font-size: .78rem
  letter-spacing: 0
  pointer-events: none

.layout.hide-aside
  max-width: 1180px

.dimflip-home
  --od-ink: #15181f
  --od-muted: #667085
  --od-line: rgba(21, 24, 31, .12)
  --od-surface: rgba(255, 255, 255, .86)
  --od-accent: #b8392e
  --od-green: #1f7a5b
  margin: 0 auto
  padding: 28px 18px 64px
  color: var(--od-ink)

  a
    color: inherit

  .od-topbar
    display: flex
    align-items: center
    justify-content: space-between
    gap: 16px
    margin-bottom: 34px
    padding-bottom: 14px
    border-bottom: 1px solid var(--od-line)

  .od-brand
    font-size: 1.08rem
    font-weight: 800
    line-height: 1

  .od-nav
    display: flex
    flex-wrap: wrap
    gap: 6px

    a
      padding: 7px 10px
      border: 1px solid transparent
      border-radius: 8px
      color: var(--od-muted)
      font-size: .9rem

      &:hover
        border-color: var(--od-line)
        color: var(--od-ink)
        background: rgba(255, 255, 255, .58)

  .od-hero
    display: grid
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px)
    gap: 32px
    align-items: end
    margin-bottom: 40px

  .od-kicker
    margin: 0 0 12px
    color: var(--od-green)
    font-size: .78rem
    font-weight: 800
    letter-spacing: 0
    text-transform: uppercase

  .od-title
    margin: 0
    max-width: 780px
    font-size: clamp(2.3rem, 7vw, 5.8rem)
    line-height: .95
    letter-spacing: 0

  .od-intro
    margin: 0
    color: var(--od-muted)
    font-size: 1rem
    line-height: 1.8

  .od-section-head
    display: flex
    align-items: baseline
    justify-content: space-between
    gap: 16px
    margin: 0 0 16px

    h2
      margin: 0
      font-size: 1rem
      letter-spacing: 0

    span
      color: var(--od-muted)
      font-size: .86rem

  .od-pinned-grid
    display: grid
    grid-template-columns: repeat(3, minmax(0, 1fr))
    gap: 16px
    margin-bottom: 42px

  .od-post-card
    overflow: hidden
    min-width: 0
    border: 1px solid var(--od-line)
    border-radius: 8px
    background: var(--od-surface)
    box-shadow: 0 18px 45px rgba(31, 35, 40, .08)

    &:hover
      transform: translateY(-2px)
      transition: transform .18s ease

  .od-post-cover
    display: block
    overflow: hidden
    aspect-ratio: 16 / 10
    background: #ded6ca

    img
      display: block
      width: 100%
      height: 100%
      object-fit: cover

  .od-post-body
    padding: 18px

  .od-meta
    display: flex
    flex-wrap: wrap
    gap: 8px
    align-items: center
    margin-bottom: 10px
    color: var(--od-muted)
    font-size: .78rem

  .od-pin
    color: var(--od-accent)
    font-weight: 800

  .od-post-title
    display: block
    margin-bottom: 9px
    font-size: 1.16rem
    font-weight: 800
    line-height: 1.35
    overflow-wrap: anywhere

  .od-excerpt
    display: -webkit-box
    overflow: hidden
    margin: 0
    color: #424956
    font-size: .92rem
    line-height: 1.7
    -webkit-line-clamp: 3
    -webkit-box-orient: vertical

  .od-tags
    display: flex
    flex-wrap: wrap
    gap: 6px
    margin-top: 14px

    span
      padding: 4px 7px
      border: 1px solid var(--od-line)
      border-radius: 8px
      color: var(--od-muted)
      font-size: .75rem

  .od-recent-list
    display: grid
    gap: 14px

  .od-post-row
    display: grid
    grid-template-columns: 220px minmax(0, 1fr)
    min-height: 150px

    .od-post-cover
      aspect-ratio: auto
      height: 100%

    .od-post-title
      font-size: 1.25rem

  .od-empty
    padding: 28px
    border: 1px dashed var(--od-line)
    border-radius: 8px
    color: var(--od-muted)
    background: rgba(255, 255, 255, .6)

@media screen and (max-width: 900px)
  .dimflip-home
    padding: 20px 14px 48px

    .od-hero
      grid-template-columns: 1fr
      gap: 18px
      margin-bottom: 30px

    .od-pinned-grid
      grid-template-columns: 1fr

    .od-post-row
      grid-template-columns: 1fr

      .od-post-cover
        aspect-ratio: 16 / 10
        height: auto

@media screen and (max-width: 520px)
  body::before
    display: none

  .dimflip-home
    .od-topbar
      align-items: flex-start
      flex-direction: column
      margin-bottom: 26px

    .od-title
      font-size: 2.4rem

    .od-section-head
      align-items: flex-start
      flex-direction: column
      gap: 4px

    .od-post-body
      padding: 15px

    .od-post-title
      font-size: 1.08rem

    .od-post-row .od-post-title
      font-size: 1.12rem
